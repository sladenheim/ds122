    "#| echo: true\n",
    "def update_bandit(distribution, outcome):\n",
    "    '''Update distribution about a machine based on win/loss outcome'''\n",
    "    if outcome == 'W':\n",
    "        update(distribution, distribution.index)\n",
    "    elif outcome == 'L':\n",
    "        update(distribution, 1 - distribution.index)"
   ]
